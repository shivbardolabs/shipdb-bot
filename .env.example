# Neon PostgreSQL connection string (get from Neon dashboard)
DATABASE_URL=postgresql://neondb_owner:***@ep-shy-glade-aie26roz.us-east-1.aws.neon.tech/neondb?sslmode=require

# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack Signing Secret (from Slack App > Basic Information)
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: Restrict raw SQL to specific Slack user IDs (comma-separated)
# Leave empty to allow all team members to run raw SQL
SQL_ALLOWED_USER_IDS=
